generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  kicker      String?
  category    String        @default("Beredskap")
  excerpt     String
  body        String
  coverImage  String?
  author      String        @default("Redaksjonen")
  featured    Boolean       @default(false)
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}
